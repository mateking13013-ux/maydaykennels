---
import { puppies } from '../data/puppies';

const homePuppyImages = [
  'https://deepskyblue-goldfinch-819888.hostingersite.com/wp-content/uploads/2025/08/TANK.jpg',
  'https://deepskyblue-goldfinch-819888.hostingersite.com/wp-content/uploads/2025/05/VICTOR-2.jpeg',
  'https://deepskyblue-goldfinch-819888.hostingersite.com/wp-content/uploads/2025/05/MISHA-6.jpeg',
  'https://deepskyblue-goldfinch-819888.hostingersite.com/wp-content/uploads/2025/05/LOTTIE-11.jpeg',
  'https://deepskyblue-goldfinch-819888.hostingersite.com/wp-content/uploads/2025/01/MOM-AND-DAD00.jpg',
  'https://deepskyblue-goldfinch-819888.hostingersite.com/wp-content/uploads/2025/05/CHESS-6.jpeg',
  'https://deepskyblue-goldfinch-819888.hostingersite.com/wp-content/uploads/2025/04/HUDSON.jpg',
  'https://deepskyblue-goldfinch-819888.hostingersite.com/wp-content/uploads/2025/04/BRUGGE.jpg'
];

const featuredPups = puppies.slice(0, 8).map((puppy, index) => ({
  name: puppy.name,
  image: homePuppyImages[index] || homePuppyImages[0],
  summary: puppy.description.split('.')[0]
}));

const steps = [
  {
    title: 'Tell us your lifestyle',
    text: 'Share your home setup, schedule, and what kind of temperament you want. We match based on fit, not pressure.'
  },
  {
    title: 'Meet your best match',
    text: 'You get videos, personality notes, and clear health records before making any final decision.'
  },
  {
    title: 'Bring your puppy home',
    text: 'Pickup details, feeding guide, and ongoing support are all included so your first week feels smooth.'
  }
];

const stories = [
  {
    quote: 'We collected our puppy in Pretoria and everything matched what we were promised. Health records, vaccine card, and feeding routine were all clear from day one.',
    name: 'Nokuthula M. - Pretoria'
  },
  {
    quote: 'From first call to pickup, communication was excellent. Our boy settled into our Johannesburg home quickly and was already crate-trained.',
    name: 'Sipho K. - Johannesburg'
  },
  {
    quote: 'The puppy sales process felt professional and honest. We received vet paperwork before pickup and support after adoption in Durban.',
    name: 'Lerato P. - Durban'
  },
  {
    quote: 'Our little girl arrived healthy, playful, and confident around kids. You can tell these puppies are raised with care in a family setting.',
    name: 'Anika V. - Cape Town'
  },
  {
    quote: 'Best breeder experience we have had. Clear updates, quick responses, and a very healthy puppy with a fantastic temperament.',
    name: 'Themba N. - Polokwane'
  },
  {
    quote: 'The handover was smooth and professional. Our puppy came with a starter guide and has been thriving since week one.',
    name: 'Johan S. - Bloemfontein'
  },
  {
    quote: 'We appreciated the health-first approach. Vaccinations and deworming were up to date, and our puppy settled in immediately.',
    name: 'Ayanda D. - East London'
  },
  {
    quote: 'They helped us choose the right puppy for our home, not just the cutest photo. The match was perfect for our family routine.',
    name: 'Kabelo R. - Midrand'
  },
  {
    quote: 'Excellent service from inquiry to pickup. Our healthy puppy is affectionate, socialized, and exactly as described.',
    name: 'Zanele T. - Port Elizabeth'
  }
];

const spotlightTestimonials = [
  {
    quote: 'Every puppy is vet checked, dewormed, and released with a clear health record so your family starts with confidence from day one.',
    family: 'Healthy Puppy Promise',
    image: 'https://deepskyblue-goldfinch-819888.hostingersite.com/wp-content/uploads/2025/05/LOTTIE-11.jpeg'
  },
  {
    quote: 'Fast and safe delivery options are available across South Africa, with travel updates and handover guidance for a smooth arrival.',
    family: 'Safe Fast Delivery',
    image: 'https://deepskyblue-goldfinch-819888.hostingersite.com/wp-content/uploads/2025/01/MOM-AND-DAD00.jpg'
  },
  {
    quote: 'Our breeding program focuses on healthy structure, gentle socialization, and daily handling so puppies are calm and family ready.',
    family: 'Responsible Breeding',
    image: 'https://deepskyblue-goldfinch-819888.hostingersite.com/wp-content/uploads/2025/05/CHESS-6.jpeg'
  },
  {
    quote: 'After-sale support includes feeding tips, settling routines, and direct help, so new owners always have guidance after pickup.',
    family: 'After-Sale Support',
    image: 'https://deepskyblue-goldfinch-819888.hostingersite.com/wp-content/uploads/2025/04/HUDSON.jpg'
  }
];

const testimonialNotes = [
  'Our vet said the records were organized and complete.',
  'Best communication we have had with any breeder.',
  'Pickup day was smooth and stress-free.',
  'Our puppy adapted quickly with their week-one guide.',
  'Photos and videos were honest and up to date.',
  'Support after adoption has been consistently helpful.'
];
---

<div class="home-redesign">
  <section class="hero reveal">
    <div class="hero-copy">
      <p class="eyebrow">Family raised puppies with a modern adoption experience</p>
      <h1>Find the puppy that fits your real life.</h1>
      <p class="hero-lede">
        We redesigned everything around clarity: better matching, verified health records,
        and a smooth handoff from our home to yours.
      </p>
      <div class="hero-actions">
        <a href="/available-puppies" class="btn-home btn-home-primary">Browse Puppies</a>
        <a href="/contact" class="btn-home btn-home-secondary">Start an Inquiry</a>
      </div>
      <div class="hero-metrics">
        <div>
          <strong>4.9/5</strong>
          <span>family rating</span>
        </div>
        <div>
          <strong>24h</strong>
          <span>response time</span>
        </div>
        <div>
          <strong>100%</strong>
          <span>health records shared</span>
        </div>
      </div>
    </div>

    <div class="hero-visual">
      <div class="photo-main">
        <img src="https://deepskyblue-goldfinch-819888.hostingersite.com/wp-content/uploads/2025/08/TANK.jpg" alt="Healthy puppy from Paws Happiness" loading="eager" />
      </div>
      <div class="photo-side">
        <img src="https://deepskyblue-goldfinch-819888.hostingersite.com/wp-content/uploads/2025/05/VICTOR-2.jpeg" alt="Paws Happiness puppy ready for a home" loading="lazy" />
      </div>
      <div class="floating-note">
        <p class="note-label">Next pickup window</p>
        <p class="note-value">This weekend</p>
      </div>
    </div>
  </section>

  <section class="proof-bar reveal">
    <div class="proof-card">
      <h3>Health checked</h3>
      <p>Vet-reviewed records and vaccine schedule sent before pickup.</p>
    </div>
    <div class="proof-card">
      <h3>Family socialized</h3>
      <p>Raised in a home setting with people, sounds, and daily routines.</p>
    </div>
    <div class="proof-card">
      <h3>Lifetime support</h3>
      <p>Guidance for food transitions, sleep routines, and behavior basics.</p>
    </div>
  </section>

  <section class="section-block reveal">
    <div class="section-head">
      <p class="eyebrow">Available companions</p>
      <h2>Choose a personality, not just a photo.</h2>
      <p class="section-copy">These are our real available puppies. View all listings or click a puppy to inquire instantly.</p>
      <a href="/available-puppies" class="section-link">View All Available Puppies</a>
    </div>

    <div class="puppy-grid">
      {featuredPups.map((pup) => (
        <article class="puppy-card">
          <button type="button" class="puppy-card-link" aria-label={`Inquire about ${pup.name}`} onclick={`openContactPopup('${pup.name.replace(/'/g, "\\'")}')`}>
            <img src={pup.image} alt={`${pup.name} puppy from Paws Happiness`} loading="lazy" />
            <div class="puppy-meta">
              <h3>{pup.name}</h3>
              <p class="puppy-summary">{pup.summary}.</p>
            </div>
          </button>
          <div class="puppy-actions">
            <button type="button" class="puppy-inquire-btn" onclick={`openContactPopup('${pup.name.replace(/'/g, "\\'")}')`}>
              Inquire About {pup.name}
            </button>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block process reveal">
    <div class="section-head">
      <p class="eyebrow">How it works</p>
      <h2>A clean, three-step adoption flow.</h2>
    </div>

    <div class="steps-grid">
      {steps.map((step, index) => (
        <article class="step-card">
          <p class="step-index">0{index + 1}</p>
          <h3>{step.title}</h3>
          <p>{step.text}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="family-promise reveal">
    <div class="promise-copy">
      <p class="eyebrow">Why families choose us</p>
      <h2>Built for trust from first message to first night home.</h2>
      <ul>
        <li>Transparent puppy notes and live updates</li>
        <li>No rushed decisions or hidden process steps</li>
        <li>Practical onboarding plan for your first week</li>
      </ul>
      <a href="/about-us" class="btn-home btn-home-primary">See Our Story</a>
    </div>
    <div class="promise-photo">
      <img src="https://deepskyblue-goldfinch-819888.hostingersite.com/wp-content/uploads/2025/05/MISHA-6.jpeg" alt="Well socialized healthy puppy from Paws Happiness" loading="lazy" />
    </div>
  </section>

  <section class="section-block reveal">
    <div class="section-head">
      <p class="eyebrow">Family stories</p>
      <h2>What recent puppy parents say.</h2>
    </div>

    <div class="story-grid">
      {stories.map((story) => (
        <article class="story-card">
          <p class="story-quote">"{story.quote}"</p>
          <p class="story-name">{story.name}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="testimonial-spotlight reveal">
    <div class="spotlight-header">
      <p class="eyebrow">More happy homes</p>
      <h2>Healthy puppies, safe delivery, and trusted support.</h2>
    </div>
    <div class="spotlight-grid">
      {spotlightTestimonials.map((item) => (
        <article class="spotlight-card">
          <img src={item.image} alt={`Paws Happiness ${item.family}`} loading="lazy" />
          <div class="spotlight-copy">
            <p class="spotlight-quote">"{item.quote}"</p>
            <p class="spotlight-family">{item.family}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-block reveal">
    <div class="section-head">
      <p class="eyebrow">Quick review snapshots</p>
      <h2>What families mention most often.</h2>
    </div>
    <div class="testimonial-notes-grid">
      {testimonialNotes.map((note) => (
        <article class="testimonial-note-card">
          <p>{note}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="final-cta reveal">
    <h2>Ready to meet your puppy match?</h2>
    <p>Tell us what you are looking for and we will send your best options first.</p>
    <a href="/contact" class="btn-home btn-home-secondary">Contact Paws Happiness</a>
  </section>
</div>

<script is:inline>
  const revealItems = document.querySelectorAll('.reveal');

  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('in-view');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });

  revealItems.forEach((item) => revealObserver.observe(item));
</script>

<style>
  .home-redesign {
    --ink: #12312b;
    --ink-soft: #335e56;
    --surface: #f4faf7;
    --surface-strong: #def3ea;
    --accent: #f59e0b;
    --accent-soft: #ffe6b5;
    --brand: #0f766e;
    --brand-dark: #0d4f49;
    background:
      radial-gradient(circle at 5% 10%, #e9fff5 0%, transparent 38%),
      radial-gradient(circle at 95% 20%, #fff1d6 0%, transparent 32%),
      var(--surface);
    color: var(--ink);
    padding: clamp(1rem, 2vw, 2rem) clamp(1rem, 4vw, 3rem) clamp(3rem, 6vw, 5rem);
  }

  .hero {
    max-width: 1240px;
    margin: 0 auto;
    display: grid;
    gap: clamp(1.5rem, 4vw, 4rem);
    grid-template-columns: repeat(2, minmax(0, 1fr));
    align-items: center;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-size: 0.76rem;
    font-weight: 700;
    color: var(--brand);
  }

  .hero-copy h1 {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(2.2rem, 5vw, 4.4rem);
    line-height: 1.03;
    color: var(--ink);
    max-width: 16ch;
  }

  .hero-lede {
    margin: 1.1rem 0 0;
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    color: var(--ink-soft);
    max-width: 50ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.6rem;
  }

  .btn-home {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.85rem 1.35rem;
    border-radius: 999px;
    font-weight: 700;
    text-decoration: none;
    border: 2px solid transparent;
    transition: transform 0.22s ease, box-shadow 0.22s ease, background 0.22s ease, color 0.22s ease;
  }

  .btn-home:hover {
    transform: translateY(-2px);
  }

  .btn-home-primary {
    background: var(--brand);
    color: #fff;
    box-shadow: 0 16px 34px rgba(15, 118, 110, 0.25);
  }

  .btn-home-primary:hover {
    background: var(--brand-dark);
    color: #fff;
  }

  .btn-home-secondary {
    background: transparent;
    color: var(--ink);
    border-color: rgba(18, 49, 43, 0.25);
  }

  .btn-home-secondary:hover {
    background: #fff;
    box-shadow: 0 14px 30px rgba(17, 24, 39, 0.12);
    color: var(--ink);
  }

  .hero-metrics {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
    margin-top: 1.6rem;
  }

  .hero-metrics div {
    background: #fff;
    border: 1px solid rgba(15, 118, 110, 0.16);
    border-radius: 14px;
    padding: 0.8rem;
    box-shadow: 0 8px 26px rgba(15, 118, 110, 0.08);
  }

  .hero-metrics strong {
    display: block;
    font-size: 1.05rem;
    color: var(--ink);
    margin-bottom: 0.1rem;
  }

  .hero-metrics span {
    font-size: 0.85rem;
    color: var(--ink-soft);
  }

  .hero-visual {
    position: relative;
    min-height: min(65vw, 600px);
    display: grid;
    place-items: center;
  }

  .photo-main,
  .photo-side {
    overflow: hidden;
    border-radius: 28px;
    box-shadow: 0 30px 60px rgba(16, 66, 59, 0.24);
  }

  .photo-main {
    width: min(100%, 530px);
    aspect-ratio: 4 / 5;
    border: 8px solid #fff;
    transform: rotate(-2deg);
  }

  .photo-side {
    position: absolute;
    width: min(58%, 280px);
    right: -2%;
    bottom: 2%;
    aspect-ratio: 4 / 5;
    border: 6px solid #fff;
    transform: rotate(6deg);
  }

  .hero-visual img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .floating-note {
    position: absolute;
    left: -2%;
    bottom: 8%;
    background: #fff;
    border: 1px solid rgba(15, 118, 110, 0.2);
    border-radius: 16px;
    padding: 0.85rem 1rem;
    box-shadow: 0 20px 34px rgba(17, 24, 39, 0.18);
    animation: bob 3.4s ease-in-out infinite;
  }

  .note-label {
    margin: 0;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.11em;
    color: var(--brand);
    font-weight: 700;
  }

  .note-value {
    margin: 0.2rem 0 0;
    font-size: 1rem;
    font-weight: 700;
    color: var(--ink);
  }

  .proof-bar {
    max-width: 1240px;
    margin: clamp(2rem, 4vw, 3.5rem) auto 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .proof-card {
    background: #fff;
    border-radius: 16px;
    padding: 1.1rem 1.2rem;
    border: 1px solid rgba(15, 118, 110, 0.14);
    box-shadow: 0 14px 34px rgba(15, 118, 110, 0.1);
  }

  .proof-card h3 {
    margin: 0;
    font-size: 1.04rem;
    color: var(--ink);
  }

  .proof-card p {
    margin: 0.55rem 0 0;
    color: var(--ink-soft);
    font-size: 0.93rem;
  }

  .section-block {
    max-width: 1240px;
    margin: clamp(3rem, 6vw, 5rem) auto 0;
  }

  .section-head h2 {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 3.3vw, 3rem);
    line-height: 1.1;
    color: var(--ink);
  }

  .section-copy {
    margin: 0.75rem 0 0;
    color: var(--ink-soft);
    max-width: 58ch;
    font-size: 0.96rem;
  }

  .section-link {
    margin-top: 1rem;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    background: var(--brand);
    color: #fff;
    padding: 0.56rem 0.95rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.82rem;
    transition: background 0.22s ease;
  }

  .section-link:hover {
    background: var(--brand-dark);
    color: #fff;
  }

  .puppy-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .puppy-card {
    background: #fff;
    border-radius: 18px;
    overflow: visible;
    border: 1px solid rgba(15, 118, 110, 0.16);
    box-shadow: 0 20px 34px rgba(15, 118, 110, 0.12);
    transition: transform 0.28s ease, box-shadow 0.28s ease;
    display: flex;
    flex-direction: column;
  }

  .puppy-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 26px 46px rgba(15, 118, 110, 0.2);
  }

  .puppy-card-link {
    text-decoration: none;
    color: inherit;
    display: block;
    width: 100%;
    appearance: none;
    -webkit-appearance: none;
    border: none;
    background: transparent;
    padding: 0;
    text-align: left;
    font: inherit;
    line-height: inherit;
    cursor: pointer;
    border-radius: 18px 18px 0 0;
    overflow: hidden;
  }

  .puppy-card-link:focus {
    outline: none;
  }

  .puppy-card-link::-moz-focus-inner {
    border: 0;
    padding: 0;
  }

  .puppy-card img {
    width: 100%;
    aspect-ratio: 4 / 4;
    object-fit: cover;
  }

  .puppy-meta {
    padding: 1rem;
  }

  .puppy-meta h3 {
    margin: 0;
    font-size: 1.12rem;
    color: var(--ink);
  }

  .puppy-meta p {
    margin: 0.35rem 0 0;
    color: var(--ink-soft);
    font-size: 0.88rem;
  }

  .puppy-meta span {
    margin-top: 0.7rem;
    display: inline-flex;
    padding: 0.34rem 0.62rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 700;
    background: var(--accent-soft);
    color: #955800;
  }

  .puppy-summary {
    margin-top: 0.65rem;
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .puppy-actions {
    display: grid;
    padding: 0 1rem 1rem;
  }

  .puppy-inquire-btn {
    border: none;
    border-radius: 10px;
    background: var(--brand);
    color: #fff;
    padding: 0.7rem 0.85rem;
    font-size: 0.84rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.22s ease;
  }

  .puppy-inquire-btn:hover {
    background: var(--brand-dark);
  }

  .process {
    position: relative;
  }

  .steps-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .step-card {
    background: linear-gradient(160deg, #ffffff, #f1faf5);
    border: 1px solid rgba(15, 118, 110, 0.18);
    border-radius: 18px;
    padding: 1.2rem;
  }

  .step-index {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--brand);
  }

  .step-card h3 {
    margin: 0.4rem 0 0;
    font-size: 1.1rem;
    color: var(--ink);
  }

  .step-card p {
    margin: 0.65rem 0 0;
    color: var(--ink-soft);
    font-size: 0.94rem;
  }

  .family-promise {
    max-width: 1240px;
    margin: clamp(3rem, 6vw, 5rem) auto 0;
    border-radius: 28px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    background: linear-gradient(145deg, #0f766e, #0b524b);
    color: #fff;
  }

  .promise-copy {
    padding: clamp(1.4rem, 4vw, 3rem);
  }

  .promise-copy .eyebrow,
  .promise-copy h2,
  .promise-copy li {
    color: #fff;
  }

  .promise-copy h2 {
    margin: 0;
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 3vw, 2.6rem);
  }

  .promise-copy ul {
    margin: 1rem 0 1.4rem;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.45rem;
  }

  .promise-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .story-grid {
    margin-top: 1.5rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .story-card {
    background: #fff;
    border-radius: 18px;
    padding: 1.2rem;
    border: 1px solid rgba(15, 118, 110, 0.14);
    box-shadow: 0 14px 30px rgba(15, 118, 110, 0.1);
  }

  .story-quote {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.95rem;
  }

  .story-name {
    margin: 0.85rem 0 0;
    font-weight: 700;
    color: var(--ink);
    font-size: 0.9rem;
  }

  .testimonial-spotlight {
    max-width: 1240px;
    margin: clamp(3rem, 6vw, 5rem) auto 0;
  }

  .spotlight-header h2 {
