<header class="site-header" id="site-header">
  <div class="header-inner">
    <a href="/" class="brand" aria-label="Paws Paradise Home">
      <img src="/images/logopaws.png" alt="Paws Paradise" />
    </a>

    <button class="menu-toggle" aria-expanded="false" aria-controls="site-nav" aria-label="Toggle navigation">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav class="site-nav" id="site-nav">
      <a href="/">Home</a>
      <a href="/about-us">About Us</a>
      <a href="/testimonials">Testimonials</a>
      <a href="/faqs">FAQs</a>
      <a href="/health-guarantee">Health Guarantee</a>
      <a href="/vaccinations">Vaccinations</a>
      <a href="/pickup-delivery">Pickup & Delivery</a>
      <a href="/contact" class="mobile-cta">Get In Touch</a>
    </nav>
    <a href="/contact" class="header-cta">Get In Touch</a>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const toggle = header?.querySelector('.menu-toggle');
  const nav = header?.querySelector('.site-nav');
  const links = header?.querySelectorAll('.site-nav a');

  const closeMenu = () => {
    header?.classList.remove('menu-open');
    toggle?.setAttribute('aria-expanded', 'false');
  };

  toggle?.addEventListener('click', () => {
    const open = header?.classList.toggle('menu-open');
    toggle?.setAttribute('aria-expanded', open ? 'true' : 'false');
  });

  links?.forEach((link) => {
    link.addEventListener('click', () => {
      if (window.innerWidth <= 980) {
        closeMenu();
      }
    });
  });

  window.addEventListener('scroll', () => {
    if (window.scrollY > 18) {
      header?.classList.add('is-scrolled');
    } else {
      header?.classList.remove('is-scrolled');
    }
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth > 980) {
      closeMenu();
    }
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: rgba(244, 250, 247, 0.84);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(15, 118, 110, 0.14);
    transition: box-shadow 0.25s ease, background 0.25s ease;
  }

  .site-header.is-scrolled {
    background: rgba(244, 250, 247, 0.95);
    box-shadow: 0 10px 26px rgba(15, 118, 110, 0.1);
  }

  .header-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 1rem;
    height: 66px;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    width: 156px;
    height: 66px;
    overflow: visible;
    gap: 0;
    line-height: 0;
    text-decoration: none;
    color: #12312b;
  }

  .brand img {
    width: 100%;
    height: auto;
    max-height: 62px;
    object-fit: contain;
  }

  .site-nav {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.15rem;
  }

  .site-nav a {
    text-decoration: none;
    color: #1a3f39;
    font-size: 0.82rem;
    font-weight: 700;
    padding: 0.48rem 0.6rem;
    border-radius: 999px;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .site-nav a:hover {
    background: rgba(15, 118, 110, 0.12);
    color: #0d4f49;
  }

  .header-cta {
    margin-left: 0.35rem;
    text-decoration: none;
    background: #0f766e;
    color: #fff;
    padding: 0.55rem 1rem;
    border-radius: 999px;
    font-size: 0.84rem;
    font-weight: 700;
    white-space: nowrap;
    transition: background 0.2s ease;
  }

  .header-cta:hover {
    background: #0d4f49;
    color: #fff;
  }

  .site-nav .mobile-cta {
    display: none;
  }

  .menu-toggle {
    display: none;
    margin-left: auto;
    border: 1px solid rgba(15, 118, 110, 0.2);
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: #fff;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    gap: 4px;
    flex-direction: column;
  }

  .menu-toggle span {
    width: 18px;
    height: 2px;
    background: #12312b;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .menu-open .menu-toggle span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .menu-open .menu-toggle span:nth-child(2) {
    opacity: 0;
  }

  .menu-open .menu-toggle span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  @media (max-width: 980px) {
    .header-inner {
      height: 64px;
    }

    .brand {
      width: 112px;
      height: 64px;
    }

    .brand img {
      width: 100%;
      height: auto;
      max-height: 56px;
    }

    .menu-toggle {
      display: inline-flex;
    }

    .site-nav {
      position: absolute;
      top: calc(100% + 8px);
      left: 1rem;
      right: 1rem;
      background: #ffffff;
      border-radius: 16px;
      border: 1px solid rgba(15, 118, 110, 0.16);
      box-shadow: 0 18px 36px rgba(15, 118, 110, 0.2);
      padding: 0.7rem;
      display: none;
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }

    .menu-open .site-nav {
      display: grid;
    }

    .site-nav a {
      padding: 0.72rem 0.8rem;
      border-radius: 10px;
    }

    .header-cta {
      display: none;
    }

    .site-nav .mobile-cta {
      display: block;
      background: #0f766e;
      color: #fff;
      text-align: center;
      margin-top: 0.25rem;
    }

    .site-nav .mobile-cta:hover {
      background: #0d4f49;
      color: #fff;
    }
  }
</style>
